local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

local player = Players.LocalPlayer
local camera = Workspace.CurrentCamera
local autoWalk = false

-- CONFIGURATION
local BASE_CYCLE = 4.0       
local movementTimer = 0      
local movingForward = true   
local currentCycleTarget = BASE_CYCLE

player.Chatted:Connect(function(msg)
	msg = msg:lower()

	if msg == "!walk on" then
		autoWalk = true
		currentCycleTarget = BASE_CYCLE + math.random(-25, 25) / 100 -- Adds human variance
		print("Auto-walk enabled with safety checks")

	elseif msg == "!walk off" then
		autoWalk = false
		print("Auto-walk disabled")
	end
end)

RunService.RenderStepped:Connect(function(deltaTime)
	if not autoWalk then
		movementTimer = 0
		movingForward = true
		return
	end

	local character = player.Character
	if not character then
		return
	end

	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if humanoid then
		movementTimer = movementTimer + deltaTime
		
		-- Safety check 1: Humanize the turn timing so it isn't pixel-perfect
		if movementTimer >= currentCycleTarget then
			movementTimer = 0
			movingForward = not movingForward
			currentCycleTarget = BASE_CYCLE + math.random(-25, 25) / 100
		end
		
		-- Safety check 2: Micro-shift the camera view randomly to simulate live touch input
		if camera and math.random(1, 30) == 1 then
			camera.CFrame = camera.CFrame * CFrame.Angles(0, math.rad(math.random(-5, 5) / 100), 0)
		end

		-- Safety check 3: Network state flush to force server-side packet updates
		if math.random(1, 500) == 1 then
			humanoid:ChangeState(Enum.HumanoidStateType.RunningNoPhysics)
			RunService.RenderStepped:Wait()
			humanoid:ChangeState(Enum.HumanoidStateType.Running)
		end
		
		-- Loop logic
		if movingForward then
			humanoid:Move(Vector3.new(0, 0, -1), true)
		else
			humanoid:Move(Vector3.new(0, 0, 1), true)
		end
	end
end)
