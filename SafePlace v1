-- Modernized SafeZone Script (Optimized & Enhanced)
repeat task.wait() until game:IsLoaded()

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local player = Players.LocalPlayer

local safeZoneFolder = nil
local running = false
local safeZoneParts = {}
local renderConnection = nil
local hueValue = 0

-- Modern UI Setup
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "SafeZoneGui"
screenGui.ResetOnSpawn = false
screenGui.Parent = player:WaitForChild("PlayerGui")

local toggleButton = Instance.new("TextButton")
toggleButton.Size = UDim2.new(0,180,0,50)
toggleButton.Position = UDim2.new(0.05, 0, 0.2, 0)
toggleButton.Text = "Enable SafeZone"
toggleButton.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
toggleButton.TextColor3 = Color3.fromRGB(240, 240, 240)
toggleButton.Font = Enum.Font.GothamBold
toggleButton.TextSize = 16
toggleButton.Active = true
toggleButton.Draggable = true
toggleButton.Parent = screenGui

local uiCorner = Instance.new("UICorner")
uiCorner.CornerRadius = UDim.new(0, 8)
uiCorner.Parent = toggleButton

local uiStroke = Instance.new("UIStroke")
uiStroke.Color = Color3.fromRGB(60, 60, 80)
uiStroke.Thickness = 1.5
uiStroke.Parent = toggleButton

-- Create SafeZone
local function createSafeZone()
	if safeZoneFolder then return end
	safeZoneFolder = Instance.new("Folder")
	safeZoneFolder.Name = "SafeZone"
	safeZoneFolder.Parent = workspace

	local cubeSize = 600
	local cubeHeight = 100
	local yPos = 3600
	local wallThickness = 20
	local entranceWidth = 100
	local pathWidth = 100
	local pathLength = 300
	local baseplateWidth = 800
	local baseplateDepth = 600

	-- Floor
	local floor = Instance.new("Part")
	floor.Size = Vector3.new(cubeSize, 10, cubeSize)
	floor.Position = Vector3.new(0, yPos + 5, 0)
	floor.Anchored = true
	floor.Material = Enum.Material.Glass
	floor.Transparency = 0.5
	floor.Reflectance = 0.4
	floor.Name = "Floor"
	floor.Parent = safeZoneFolder
	table.insert(safeZoneParts, floor)

	-- Wall Helper with Neon Borders
	local function createWall(position, size)
		local wall = Instance.new("Part")
		wall.Size = size
		wall.Position = position
		wall.Anchored = true
		wall.Material = Enum.Material.Glass
		wall.Transparency = 0.7
		wall.Parent = safeZoneFolder
		table.insert(safeZoneParts, wall)

		-- Futuristic Glow Trim
		local trim = Instance.new("Part")
		trim.Size = Vector3.new(size.X + 2, 4, size.Z + 2)
		trim.Position = position + Vector3.new(0, (size.Y / 2) - 2, 0)
		trim.Anchored = true
		trim.Material = Enum.Material.Neon
		trim.Parent = safeZoneFolder
		table.insert(safeZoneParts, trim)
	end

	createWall(Vector3.new(-cubeSize/2, yPos + cubeHeight/2, 0), Vector3.new(wallThickness, cubeHeight, cubeSize))
	createWall(Vector3.new(cubeSize/2, yPos + cubeHeight/2, 0), Vector3.new(wallThickness, cubeHeight, cubeSize))
	createWall(Vector3.new(0, yPos + cubeHeight/2, cubeSize/2), Vector3.new(cubeSize, cubeHeight, wallThickness))

	-- Front wall split for entrance
	local frontLeft = Instance.new("Part")
	frontLeft.Size = Vector3.new((cubeSize - entranceWidth) / 2, cubeHeight, wallThickness)
	frontLeft.Position = Vector3.new(-(cubeSize - entranceWidth) / 4 - entranceWidth / 2, yPos + cubeHeight / 2, -cubeSize / 2)
	frontLeft.Anchored = true
	frontLeft.Material = Enum.Material.Glass
	frontLeft.Transparency = 0.7
	frontLeft.Parent = safeZoneFolder
	table.insert(safeZoneParts, frontLeft)

	local frontRight = Instance.new("Part")
	frontRight.Size = Vector3.new((cubeSize - entranceWidth) / 2, cubeHeight, wallThickness)
	frontRight.Position = Vector3.new((cubeSize - entranceWidth) / 4 + entranceWidth / 2, yPos + cubeHeight / 2, -cubeSize / 2)
	frontRight.Anchored = true
	frontRight.Material = Enum.Material.Glass
	frontRight.Transparency = 0.7
	frontRight.Parent = safeZoneFolder
	table.insert(safeZoneParts, frontRight)

	-- Access Path
	local path = Instance.new("Part")
	path.Size = Vector3.new(pathWidth, 10, pathLength)
	path.Position = Vector3.new(0, yPos + 5, -cubeSize / 2 - pathLength / 2)
	path.Anchored = true
	path.Material = Enum.Material.SmoothPlastic
	path.Color = Color3.fromRGB(40, 40, 45)
	path.Parent = safeZoneFolder

	-- Baseplate
	local baseplate = Instance.new("Part")
	baseplate.Size = Vector3.new(baseplateWidth, 10, baseplateDepth)
	baseplate.Position = Vector3.new(0, yPos - 5, -cubeSize / 2 - pathLength - baseplateDepth / 2)
	baseplate.Anchored = true
	baseplate.Material = Enum.Material.Grass
	baseplate.Color = Color3.fromRGB(34, 139, 34)
	baseplate.Parent = safeZoneFolder

	-- Sign Board with Hover Tween
	local signPart = Instance.new("Part")
	signPart.Size = Vector3.new(120, 30, 2)
	signPart.Position = Vector3.new(0, yPos + 60, -cubeSize / 2 - pathLength - baseplateDepth / 2)
	signPart.Anchored = true
	signPart.Material = Enum.Material.Neon
	signPart.Transparency = 0.2
	signPart.Parent = safeZoneFolder
	table.insert(safeZoneParts, signPart)

	local billboard = Instance.new("BillboardGui")
	billboard.Size = UDim2.new(0, 300, 0, 100)
	billboard.AlwaysOnTop = true
	billboard.Adornee = signPart
	billboard.Parent = signPart

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, 0, 1, 0)
	label.BackgroundTransparency = 1
	label.Text = "Made by Avery"
	label.TextScaled = true
	label.Font = Enum.Font.GothamBold
	label.Parent = billboard

	-- Clean Float Animation
	local tweenInfo = TweenInfo.new(2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true)
	local hoverTween = TweenService:Create(signPart, tweenInfo, {Position = signPart.Position + Vector3.new(0, 8, 0)})
	hoverTween:Play()

	-- Centered Unified Render Loop
	renderConnection = RunService.RenderStepped:Connect(function(deltaTime)
		hueValue = (hueValue + deltaTime * 0.1) % 1
		local mainColor = Color3.fromHSV(hueValue, 0.7, 1)
		
		-- Update Text Color
		if label and label.Parent then
			label.TextColor3 = mainColor
		end
		
		-- Update Structure Colors
		for i = #safeZoneParts, 1, -1 do
			local part = safeZoneParts[i]
			if part and part.Parent then
				part.Color = mainColor
			else
				table.remove(safeZoneParts, i)
			end
		end
	end)
end

-- Clear SafeZone Safely
local function removeSafeZone()
	if renderConnection then
		renderConnection:Disconnect()
		renderConnection = nil
	end
	if safeZoneFolder then
		safeZoneFolder:Destroy()
		safeZoneFolder = nil
	end
	table.clear(safeZoneParts)
end

-- Button Logic & Visual Feedback
toggleButton.MouseButton1Click:Connect(function()
	running = not running
	
	-- Instant Button Feedback
	if running then
		createSafeZone()
		toggleButton.Text = "Disable SafeZone"
		TweenService:Create(toggleButton, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(180, 40, 40)}):Play()
		TweenService:Create(uiStroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(220, 60, 60)}):Play()
	else
		removeSafeZone()
		toggleButton.Text = "Enable SafeZone"
		TweenService:Create(toggleButton, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(25, 25, 35)}):Play()
		TweenService:Create(uiStroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(60, 60, 80)}):Play()
	end
end)
