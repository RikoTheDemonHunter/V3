	local old = mt.__namecall
	local protect = newcclosure or function(f) return f end
	setreadonly(mt, false)
	mt.__namecall = protect(function(self, ...)
		local method = getnamecallmethod()
		if method == "Kick" then
			task.wait(9e9)
			return
		end
		return old(self, ...)
	end)
end)

