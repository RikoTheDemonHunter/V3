-- Helper function to style Sidebar Category Tabs
local function createCategoryTab(name, posIndex, callback)
	local btn = Instance.new("TextButton")
	btn.Parent = Menu
	btn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
	btn.BorderColor3 = Color3.fromRGB(255, 0, 0)
	btn.Position = UDim2.new(0, 5, 0, (posIndex * 30) - 25)
	btn.Size = UDim2.new(1, -10, 0, 25)
	btn.Font = Enum.Font.GothamBlack
	btn.Text = name
	btn.TextColor3 = Color3.fromRGB(255, 0, 0)
	btn.TextSize = 10
	btn.MouseButton1Down:Connect(callback)
	return btn
end

-- Helper function to style Action Buttons inside the Content Area
local function styleActionButton(btn, name, xPos, yPos, textSz)
	btn.Parent = ContentFrame
	btn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
	btn.BorderColor3 = Color3.fromRGB(255, 0, 0)
	btn.Position = UDim2.new(0, xPos, 0, yPos)
	btn.Size = UDim2.new(0, 105, 0, 30)
	btn.Font = Enum.Font.GothamBlack
	btn.Text = name
	btn.TextColor3 = Color3.fromRGB(255, 0, 0)
	btn.TextSize = textSz or 11
	btn.Visible = false
end

