-- Category 4: Drink Settings (OVERLOAD PROTECTED AUTO FARM)
local DrinkSettings = createCategoryTab("Drink Settings", 4, function()
	hideAllSubMenus()
	AutoDrinkSwitcher.Visible = true
end)

styleActionButton(AutoDrinkSwitcher, "Auto Drink Switcher", 0, 0, 9)
AutoDrinkSwitcher.MouseButton1Down:Connect(function()
	AutoDrinkSwitcher.Text = "Running Auto..."
	
	local Players = game:GetService("Players")
	local localPlayer = Players.LocalPlayer

	local DRINK_ORDER = {
		"Garlic Juice", "Thunder Fizz", "Omega Burp Juice", "Atomic Drink", 
		"Ninth Drink", "Sixth Drink", "Fifth Drink", "Fourth Drink", "Third Drink",
		"Twelfth Drink", "Eleventh Drink", "Tenth Drink", "Eighth Drink", 
		"Seventh Drink", "Second Drink", "Starter Drink"
	}

	local function getBestOwnedDrink()
		local character = localPlayer.Character
		local backpack = localPlayer:FindFirstChild("Backpack")
		for _, drinkName in ipairs(DRINK_ORDER) do
			if (backpack and backpack:FindFirstChild(drinkName)) or (character and character:FindFirstChild(drinkName)) then
				return drinkName
			end
		end
		return nil
	end

	-- Thread 1: Handles smooth auto-equipping without stuttering
	task.spawn(function()
		while true do
			local character = localPlayer.Character
			local backpack = localPlayer:FindFirstChild("Backpack")
			
			if character and backpack then
				local humanoid = character:FindFirstChildOfClass("Humanoid")
				local bestDrink = getBestOwnedDrink()
				
				if humanoid and humanoid.Health > 0 and bestDrink then
					local equippedTool = character:FindFirstChildOfClass("Tool")
					if not equippedTool or equippedTool.Name ~= bestDrink then
						local targetTool = backpack:FindFirstChild(bestDrink)
						if targetTool then
							humanoid:EquipTool(targetTool)
						end
					end
				end
			end
			task.wait()
		end
	end)

	-- Thread 2: Handles ultra-fast clicking without overload lockouts
	task.spawn(function()
		while true do
			local character = localPlayer.Character
			if character then
				local equippedTool = character:FindFirstChildOfClass("Tool")
				-- Verifies it's a valid drink script target before clicking
				if equippedTool and table.find(DRINK_ORDER, equippedTool.Name) then
					equippedTool:Activate()
				end
			end
			task.wait() -- Safe high-speed click threshold to prevent game crashes
		end
	end)
end)

